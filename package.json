{
  "name": "aegisrisk-platform",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "dev:api": "pnpm --filter @aegisrisk/api start:dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "test": "pnpm --filter @aegisrisk/api test",
    "db:generate": "pnpm --filter @aegisrisk/database prisma:generate",
    "db:migrate": "pnpm --filter @aegisrisk/database prisma:migrate",
    "db:seed": "pnpm --filter @aegisrisk/database prisma:seed"
  }
}
